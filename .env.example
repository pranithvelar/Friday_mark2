# Friday Mark 2 — LLM Slot Configuration
# =========================================
# Copy this file to .env and fill in your values.
# Environment variables set in your shell always take priority over this file.

# ── Slot 1: API Provider (any OpenAI-compatible endpoint) ──────────────────────
# Leave LLM_API_KEY empty to skip API slot and go straight to Ollama.

LLM_API_KEY=
# LLM_API_KEY=sk-or-v1-...        # OpenRouter
# LLM_API_KEY=AIza...              # Gemini (use compat endpoint below)
# LLM_API_KEY=sk-...               # OpenAI
# LLM_API_KEY=sk-...               # DeepSeek
# LLM_API_KEY=gsk_...              # Groq

LLM_API_BASE_URL=
# LLM_API_BASE_URL=https://openrouter.ai/api/v1                          # OpenRouter (routes to Claude, GPT, Gemini, DeepSeek, etc.)
# LLM_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/  # Gemini direct
# LLM_API_BASE_URL=https://api.deepseek.com/v1                           # DeepSeek
# LLM_API_BASE_URL=https://api.groq.com/openai/v1                        # Groq
# LLM_API_BASE_URL=https://api.mistral.ai/v1                             # Mistral
# LLM_API_BASE_URL=https://api.together.xyz/v1                           # Together AI
# (leave blank for native OpenAI endpoint)

LLM_API_MODEL=gpt-4o-mini
# LLM_API_MODEL=anthropic/claude-3-5-sonnet  # via OpenRouter
# LLM_API_MODEL=gemini-2.5-flash             # via OpenRouter or Gemini direct
# LLM_API_MODEL=deepseek-chat                # via DeepSeek
# LLM_API_MODEL=llama-3.3-70b-versatile     # via Groq (free tier)
# LLM_API_MODEL=meta-llama/llama-3.3-70b-instruct:free  # via OpenRouter free tier

# ── Slot 2: Ollama fallback (always available) ─────────────────────────────────
LLM_OLLAMA_MODEL=llama3.1:8b
